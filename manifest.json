{
  "manifest_version": 3,
  "name": "Google Maps List Extractor",
  "version": "1.0.0",
  "description": "Extract all places from a Google Maps shared list as text or CSV.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["https://www.google.com/maps/*", "https://nominatim.openstreetmap.org/*"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
